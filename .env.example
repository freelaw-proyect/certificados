# Primera vez: python3 -m venv .venv && .venv/bin/pip install -r requirements.txt
# Arranque local: source .venv/bin/activate && uvicorn main:app --host 0.0.0.0 --port 8765 --reload
# Render.com (recomendado): Environment = Docker, Dockerfile en la raíz del servicio.
# Webhook: https://TU-SERVICIO.onrender.com/webhooks/email2json
# Sin Docker, Playwright falla: "Executable doesn't exist" → falta playwright install chromium.
# Render nativo: uvicorn main:app --host 0.0.0.0 --port $PORT  (solo API/email, sin navegador)
# (Si no existe .venv, source .venv/bin/activate falla; uvicorn puede seguir viniendo de conda/global.)

# Cookie completa del navegador (misma cabecera Cookie que en el curl)
REGISTROCIVIL_COOKIE=
# O archivo de una línea (copia cookie.rc.txt.example → cookie.rc.txt)
REGISTROCIVIL_COOKIE_FILE=cookie.rc.txt

# false = usar cookie/env y ejecutar entrega HTTP al correo (recomendado tras captcha manual)
REGISTROCIVIL_USE_SELENIUM=false
REGISTROCIVIL_SELENIUM_HEADLESS=true
REGISTROCIVIL_SELENIUM_TIMEOUT_SEC=60
# Con HEADLESS=false: cuánto esperar (s) a que resuelvas el captcha del RC en la ventana de Chrome.
REGISTROCIVIL_SELENIUM_MANUAL_CAPTCHA_TIMEOUT_SEC=420
# Si Selenium falla, usar REGISTROCIVIL_COOKIE del .env (por defecto false: evita sesiones caducas).
REGISTROCIVIL_SELENIUM_FALLBACK_ENV_COOKIE=false
# Opcional: ruta al ejecutable Chrome/Chromium (Docker / Linux)
# REGISTROCIVIL_CHROME_BINARY=

# UI web: GET / y WebSocket /ws/entrega-certificado (captcha por imagen en el navegador).
# REGISTROCIVIL_WS_TOKEN=                    # si se define, el WS exige ?token=igual (seguridad).
# playwright (recomendado) o selenium
REGISTROCIVIL_BROWSER_BACKEND=playwright
# Local + reCAPTCHA: false (Mac). Render/Docker con reCAPTCHA:
#   REGISTROCIVIL_WS_BROWSER_HEADLESS=false
#   REGISTROCIVIL_USE_XVFB=true          # pantalla virtual en el contenedor (docker-entrypoint.sh)
# Sin Xvfb en Render nativo Python: usa REGISTROCIVIL_COOKIE o solo captcha-imagen.
REGISTROCIVIL_WS_BROWSER_HEADLESS=false
# REGISTROCIVIL_USE_XVFB=true
# REGISTROCIVIL_WS_SELENIUM_HEADLESS=false   # solo aplica si BROWSER_BACKEND=selenium

# true (recomendado): nacimiento + defunción + matrimonio en un carrito; una entrega al correo.
# false: solo REGISTROCIVIL_DEFAULT_ID_CERTIFICADO.
REGISTROCIVIL_DEFAULT_PACK_TRES_CERTIFICADOS=true
REGISTROCIVIL_DEFAULT_PACK_ID_NACIMIENTO=133_1_2
REGISTROCIVIL_DEFAULT_PACK_ID_DEFUNCION=3_3_1
REGISTROCIVIL_DEFAULT_PACK_ID_MATRIMONIO=2_2_2
# Acuerdo de unión civil (idCertificado en agregarACarro.srcei). Vacío = no se intenta.
REGISTROCIVIL_DEFAULT_PACK_ID_UNION_CIVIL=9_11_1
REGISTROCIVIL_DEFAULT_PACK_UNION_CIVIL_ENTREGA_VARIANT=matrimonio

# Valores por defecto del POST (copia aquí lo mismo que en tu curl / formulario)
# RUN con puntos y DV (17.402.744-7) o solo dígitos+DV sin guion (174027447 → 17.402.744-7). Nueve dígitos antes del guion = error.
REGISTROCIVIL_DEFAULT_RUN=
# Correo donde el RC envía el certificado.
# Recomendado: dirección *@email2json.com (https://www.email2json.com/) → webhook POST a este servicio.
# 1) Crea webhook en email2json apuntando a tu URL pública (local: ngrok http 8765 → .../webhooks/email2json)
# 2) GET http://127.0.0.1:8765/webhooks/email2json/setup para ver webhook_url
# 3) Pega aquí el *@email2json.com que te den
REGISTROCIVIL_DEFAULT_EMAIL=
# Token opcional (?token=) para proteger el webhook
# REGISTROCIVIL_EMAIL2JSON_WEBHOOK_TOKEN=
# REGISTROCIVIL_EMAIL2JSON_INBOX_DIR=incoming
# REGISTROCIVIL_EMAIL2JSON_FORWARD_URL=   # reenviar JSON a freelaw-backend u otro

# Árbol familiar (POST /registrocivil/arbol-certificados + PDF nacimiento del consultado)
# REGISTROCIVIL_GENEALOGY_OUTPUT_DIR=salida
# REGISTROCIVIL_GENEALOGY_MAX_GENERATION=2
# REGISTROCIVIL_GENEALOGY_POLL_AFTER_REQUEST_SEC=120
# Documento del solicitante (RUN/cédula/pasaporte). No uses +569… ni 09… (celular): el API fuerza ok=false.
REGISTROCIVIL_DEFAULT_NUMERO_DOCUMENTO_SOL=
# Teléfono de contacto en el formulario de entrega (opcional).
REGISTROCIVIL_ENTREGA_TELEFONO=
# Opcionales (vacío = se usa el RUN principal en carro_runConsulta / carro_runSolicitante)
REGISTROCIVIL_DEFAULT_CARRO_RUN_CONSULTA=
REGISTROCIVIL_DEFAULT_CARRO_RUN_SOLICITANTE=
REGISTROCIVIL_DEFAULT_CARRO_RUN_NACIONALIDAD=53
# Nacimiento: 133_1_2 — Defunción: 3_3_1 — Matrimonio: 2_2_2 — Acuerdo unión civil: 9_11_1
# Con 3_3_1, si el RUN no tiene defunción inscrita, el RC responde error (no es fallo de este servicio).
REGISTROCIVIL_DEFAULT_ID_CERTIFICADO=133_1_2
REGISTROCIVIL_DEFAULT_FILTRO=99
REGISTROCIVIL_DEFAULT_SOLICITAR_APOSTILLA=false
REGISTROCIVIL_DEFAULT_SOLICITAR_VALIJA=false

# Defunción (dejar ENTREGA_VARIANT en standard / omitirlo):
# REGISTROCIVIL_DEFAULT_ID_CERTIFICADO=3_3_1
# REGISTROCIVIL_DEFAULT_FILTRO=99

# Matrimonio: mismos pasos HTTP pero URLs de entrega/post distintas y nombres de campo del POST (curl del navegador).
# REGISTROCIVIL_ENTREGA_VARIANT=matrimonio
# REGISTROCIVIL_DEFAULT_ID_CERTIFICADO=2_2_2
# REGISTROCIVIL_ENTREGA_EMAIL_CONFIRM=   (vacío = mismo que DEFAULT_EMAIL)
# REGISTROCIVIL_ENTREGA_EMAIL2=
# REGISTROCIVIL_ENTREGA_EMAIL_CONFIRM2=
# REGISTROCIVIL_DEFAULT_NAME_CHECK_APOSTILLA=false
# REGISTROCIVIL_DEFAULT_NAME_PAIS_APOSTILLA=-1
